---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const notes = await getCollection('theory');
  // prev/next：同系列內按 order 排（跨系列不串——兩系列是不同閱讀動線）
  const sorted = [...notes].sort((a, b) => a.data.order - b.data.order);
  return notes.map((note) => {
    const siblings = sorted.filter((n) => n.data.series === note.data.series);
    const i = siblings.findIndex((n) => n.id === note.id);
    return {
      params: { slug: note.id },
      props: {
        note,
        prev: i > 0 ? siblings[i - 1] : null,
        next: i < siblings.length - 1 ? siblings[i + 1] : null,
      },
    };
  });
}

const { note, prev, next } = Astro.props;
const { Content } = await render(note);

const seriesName =
  note.data.series === 'framing' ? '意義建構系列' : '實踐認識論系列';
---

<Base title={note.data.title} description={note.data.description}>
  <h1>{note.data.title}</h1>
  <p class="note-meta">
    <a href="/theory/">理論筆記</a> · {seriesName} 第 {note.data.order} 篇
  </p>
  <Content />
  <nav class="note-nav">
    {prev ? (
      <a href={`/theory/${prev.id}/`}>← {prev.data.title}</a>
    ) : (
      <span></span>
    )}
    {next ? (
      <a href={`/theory/${next.id}/`}>{next.data.title} →</a>
    ) : (
      <span></span>
    )}
  </nav>
</Base>
