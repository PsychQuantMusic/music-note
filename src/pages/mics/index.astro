---
import Base from '../../layouts/Base.astro';
import { getAllMics } from '../../lib/mics';

const mics = getAllMics();

const TYPE_NAMES: Record<string, string> = {
  dynamic: '動圈（Dynamic）',
  condenser: '電容（Condenser）',
  'small-diaphragm condenser': '小振膜電容（SDC）',
  'large-diaphragm condenser': '大振膜電容（LDC）',
  ribbon: '鋁帶（Ribbon）',
};

const types = [...new Set(mics.map((m) => m.type))].sort();
const byType = types.map((t) => ({
  type: t,
  name: TYPE_NAMES[t] ?? t,
  mics: mics.filter((m) => m.type === t),
}));
---

<Base title="麥克風頻響資料庫" description="從官方頻響圖描點還原的麥克風頻率響應資料庫">
  <h1>麥克風頻響資料庫</h1>
  <p>
    {mics.length} 支麥克風、{mics.reduce((n, m) => n + m.curves.length, 0)} 條頻響曲線。
    全部從官方 spec sheet 描點還原、逐點驗證；曲線逐點忠於量測數據，不平滑、不重採樣。
  </p>

  <div class="mic-filter">
    <div class="mic-filter-chips" id="type-chips">
      <button class="chip" data-type="" aria-pressed="true">全部</button>
      {byType.map((g) => (
        <button class="chip" data-type={g.type} aria-pressed="false">{g.name}</button>
      ))}
    </div>
    <input type="search" id="mic-search" placeholder="搜尋品牌／型號…" aria-label="搜尋麥克風" />
  </div>

  {byType.map((g) => (
    <section data-type-section={g.type}>
      <h2>{g.name}</h2>
      <ul class="note-list">
        {g.mics.map((m) => (
          <li data-name={`${m.brand} ${m.model}`.toLowerCase()}>
            <div class="note-title">
              <a href={`/mics/${m.slug}/`}>{m.brand} {m.model}</a>
            </div>
            <div class="note-desc">
              {m.curves.length} 條曲線
              {m.polarCurves.length > 0 && `（+${m.polarCurves.length} polar）`}
              {m.polarPatterns.length > 0 && ` · ${m.polarPatterns.join(' / ')}`}
              {m.frequencyRange && ` · ${m.frequencyRange[0]}–${m.frequencyRange[1] >= 1000 ? `${m.frequencyRange[1] / 1000}k` : m.frequencyRange[1]} Hz`}
            </div>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Base>

<script>
  // 索引篩選（#4）：type chip + 文字過濾，純 client、無重載；空分組整段隱藏
  const chips = document.querySelectorAll<HTMLButtonElement>('#type-chips .chip');
  const search = document.getElementById('mic-search') as HTMLInputElement;
  let activeType = '';

  function apply() {
    const q = search.value.trim().toLowerCase();
    for (const sec of document.querySelectorAll<HTMLElement>('[data-type-section]')) {
      const typeOk = !activeType || sec.dataset.typeSection === activeType;
      let visible = 0;
      for (const li of sec.querySelectorAll<HTMLElement>('li[data-name]')) {
        const show = typeOk && (!q || li.dataset.name!.includes(q));
        li.style.display = show ? '' : 'none';
        if (show) visible++;
      }
      sec.style.display = visible ? '' : 'none';
    }
  }

  for (const chip of chips) {
    chip.addEventListener('click', () => {
      activeType = chip.dataset.type ?? '';
      for (const c of chips) c.setAttribute('aria-pressed', String(c === chip));
      apply();
    });
  }
  search.addEventListener('input', apply);
</script>
